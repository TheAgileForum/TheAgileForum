# Optional: absolute API base when not using Vite dev proxy or same-origin /api rewrite.
# Vercel staging: leave unset — vercel.json proxies /api; app ignores VITE_API_URL on app.staging host.
# Local dev: leave unset — Vite proxies /api → http://localhost:3001
# See docs/staging-deploy.md
# VITE_API_URL=https://api.staging.theagileforum.com

# Optional: public runtime label for UI diagnostics.
# VITE_APP_ENV=development

# Optional: Microsoft Clarity project id for browser session analytics.
# VITE_CLARITY_PROJECT_ID=

# Optional: PostHog project API key for browser event capture (staging/prod).
# Same phc_ key as server POSTHOG_API_KEY in the PostHog project.
# VITE_POSTHOG_KEY=
# VITE_POSTHOG_HOST=https://us.i.posthog.com
# VITE_OBSERVABILITY_RELEASE=staging
