generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  CUSTOMER
  RESTAURANT_MANAGER
  DELIVERY_PARTNER
  OPS_ADMIN
  SUPPORT_AGENT
}

model Tenant {
  id            String              @id @default(uuid())
  name          String
  memberships   TenantMembership[]
  consentEvents ConsentEvent[]
  carts         Cart[]
  orders        Order[]

  @@map("tenants")
}

model User {
  id                          String              @id @default(uuid())
  email                       String              @unique
  passwordHash                String              @map("password_hash")
  displayName                 String?             @map("display_name")
  pictureUrl                  String?             @map("picture_url")
  oauthSubject                String?             @map("oauth_subject")
  oauthProfileUrl             String?             @map("oauth_profile_url")
  emailVerifiedAt             DateTime?           @map("email_verified_at")
  emailVerificationToken      String?             @unique @map("email_verification_token")
  emailVerificationExpiresAt  DateTime?           @map("email_verification_expires_at")
  passwordResetToken          String?             @unique @map("password_reset_token")
  passwordResetExpiresAt      DateTime?           @map("password_reset_expires_at")
  authProvider                String?             @map("auth_provider")
  memberships                 TenantMembership[]
  consentEvents               ConsentEvent[]
  carts                       Cart[]
  orders                      Order[]
  diagnosisSessions           DiagnosisSession[]

  @@map("users")
}

model TenantMembership {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  tenantId  String   @map("tenant_id")
  role      Role
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([userId, tenantId])
  @@map("tenant_memberships")
}

model RoleDefinition {
  id          String           @id @default(uuid())
  key         String           @unique
  displayName String           @map("display_name")
  isSystem    Boolean          @default(true) @map("is_system")
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")
  permissions RolePermission[]

  @@map("role_definitions")
}

model Permission {
  id          String           @id @default(uuid())
  key         String           @unique
  description String?
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")
  roles       RolePermission[]

  @@map("permissions")
}

model RolePermission {
  id               String         @id @default(uuid())
  roleDefinitionId String         @map("role_definition_id")
  permissionId     String         @map("permission_id")
  createdAt        DateTime       @default(now()) @map("created_at")
  roleDefinition   RoleDefinition @relation(fields: [roleDefinitionId], references: [id], onDelete: Cascade)
  permission       Permission     @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleDefinitionId, permissionId])
  @@map("role_permissions")
}

model ConsentEvent {
  id            String    @id @default(uuid())
  userId        String    @map("user_id")
  tenantId      String?   @map("tenant_id")
  policyVersion String    @map("policy_version")
  accepted      Boolean
  source        String
  createdAt     DateTime  @default(now()) @map("created_at")
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant        Tenant?   @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([tenantId])
  @@unique([userId, policyVersion, source])
  @@map("consent_events")
}

model EventLog {
  id             String   @id @default(uuid())
  eventName      String   @map("event_name")
  payload        Json
  source         String
  idempotencyKey String   @unique @map("idempotency_key")
  status         String   @default("pending")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@index([eventName, createdAt])
  @@index([status, createdAt])
  @@map("events")
}

model JobRun {
  id         String   @id @default(uuid())
  jobType    String   @map("job_type")
  queue      String
  runAt      DateTime @map("run_at")
  attempts   Int      @default(0)
  status     String   @default("queued")
  error      String?
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@index([queue, status, runAt])
  @@map("jobs")
}

model Cart {
  id         String     @id @default(uuid())
  userId     String     @map("user_id")
  tenantId   String?    @map("tenant_id")
  status     String     @default("active")
  currency   String
  createdAt  DateTime   @default(now()) @map("created_at")
  updatedAt  DateTime   @updatedAt @map("updated_at")
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant     Tenant?    @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  items      CartItem[]
  orders     Order[]

  @@index([userId, status])
  @@index([tenantId])
  @@map("carts")
}

model CartItem {
  id           String   @id @default(uuid())
  cartId       String   @map("cart_id")
  offeringCode String   @map("offering_code")
  scheduleRef  String?  @map("schedule_ref")
  quantity     Int      @default(1)
  unitPrice    Decimal  @db.Decimal(10, 2) @map("unit_price")
  currency     String
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  cart         Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)

  @@index([cartId])
  @@map("cart_items")
}

model GuestCart {
  id           String          @id @default(uuid())
  sessionToken String          @unique @map("session_token")
  status       String          @default("active")
  currency     String          @default("USD")
  createdAt    DateTime        @default(now()) @map("created_at")
  updatedAt    DateTime        @updatedAt @map("updated_at")
  items        GuestCartItem[]

  @@index([sessionToken, status])
  @@map("guest_carts")
}

model GuestCartItem {
  id           String    @id @default(uuid())
  guestCartId  String    @map("guest_cart_id")
  offeringCode String    @map("offering_code")
  scheduleRef  String?   @map("schedule_ref")
  quantity     Int       @default(1)
  unitPrice    Decimal   @db.Decimal(10, 2) @map("unit_price")
  currency     String
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  guestCart    GuestCart @relation(fields: [guestCartId], references: [id], onDelete: Cascade)

  @@index([guestCartId])
  @@map("guest_cart_items")
}

model Order {
  id           String      @id @default(uuid())
  orderNumber  String      @unique @map("order_number")
  userId       String      @map("user_id")
  tenantId     String?     @map("tenant_id")
  cartId       String?     @map("cart_id")
  status       String      @default("created")
  currency     String
  totalAmount  Decimal     @db.Decimal(10, 2) @map("total_amount")
  paymentRef   String?     @map("payment_ref")
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant       Tenant?     @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  cart         Cart?       @relation(fields: [cartId], references: [id], onDelete: SetNull)
  items        OrderItem[]

  @@index([userId, createdAt])
  @@index([status, createdAt])
  @@map("orders")
}

model OrderItem {
  id           String   @id @default(uuid())
  orderId      String   @map("order_id")
  offeringCode String   @map("offering_code")
  quantity     Int      @default(1)
  unitPrice    Decimal  @db.Decimal(10, 2) @map("unit_price")
  currency     String
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  order        Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@map("order_items")
}

enum DiagnosisSessionStatus {
  DRAFT
  INTENT_SAVED
  INPUT_READY
  ANALYZING
  COMPLETED
}

enum DiagnosisStep {
  STEP_1
  STEP_2
  STEP_3
  STEP_4
}

enum ResumeAssetStatus {
  PENDING
  VALIDATED
  FAILED
}

enum AnalysisRunStatus {
  QUEUED
  PROCESSING
  COMPLETED
  FAILED
  TIMEOUT
}

enum AnalysisStage {
  PARSING
  MAPPING
  INSIGHTS
}

enum JourneySubjectType {
  SESSION
  USER
}

enum OfferingKind {
  course
  exam
  certification_mock
  service
}

enum OfferingCategory {
  training
  certification
  service
}

enum ExamAccessPolicy {
  free
  paid
  preview_only
}

enum DeliveryMode {
  live
  self_paced
}

model Offering {
  id                     String             @id @default(uuid())
  code                   String             @unique
  title                  String
  kind                   OfferingKind
  category               OfferingCategory
  scheduleBound          Boolean            @map("schedule_bound")
  examAccess             ExamAccessPolicy   @map("exam_access")
  safeOrgPaymentEligible Boolean            @default(false) @map("safe_org_payment_eligible")
  defaultUnitPrice       Decimal            @db.Decimal(10, 2) @map("default_unit_price")
  currency               String             @default("USD")
  roleTags               Json               @map("role_tags")
  certBody               String?            @map("cert_body")
  deliveryMode           DeliveryMode       @map("delivery_mode")
  enabled                Boolean            @default(true)
  deletedAt              DateTime?          @map("deleted_at")
  createdAt              DateTime           @default(now()) @map("created_at")
  updatedAt              DateTime           @updatedAt @map("updated_at")
  schedules              OfferingSchedule[]

  @@index([category, enabled])
  @@index([enabled, deletedAt])
  @@map("offerings")
}

model OfferingSchedule {
  id         String    @id @default(uuid())
  offeringId String    @map("offering_id")
  refCode    String    @map("ref_code")
  label      String?
  startsAt   DateTime? @map("starts_at")
  enabled    Boolean   @default(true)
  deletedAt  DateTime? @map("deleted_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  offering   Offering  @relation(fields: [offeringId], references: [id], onDelete: Cascade)

  @@unique([offeringId, refCode])
  @@index([offeringId, enabled])
  @@map("offering_schedules")
}

model DiagnosisSession {
  id             String                 @id @default(uuid())
  userId         String?                @map("user_id")
  status         DiagnosisSessionStatus @default(DRAFT)
  currentStep    DiagnosisStep          @default(STEP_1) @map("current_step")
  roleIntent     String?                @map("role_intent")
  targetRole     String?                @map("target_role")
  timeline       String?
  currentStatus  String?                @map("current_status")
  consentAck     Boolean                @default(false) @map("consent_ack")
  consentAt      DateTime?              @map("consent_at")
  policyVersion  String?                @map("policy_version")
  campaignId     String?                @map("campaign_id")
  createdAt      DateTime               @default(now()) @map("created_at")
  updatedAt      DateTime               @updatedAt @map("updated_at")
  user           User?                  @relation(fields: [userId], references: [id], onDelete: SetNull)
  resumeAssets   ResumeAsset[]
  jdInput        JdInput?
  analysisRuns   AnalysisRun[]
  journeyStates  JourneyState[]

  @@index([userId, updatedAt])
  @@map("diagnosis_sessions")
}

model ResumeAsset {
  id          String            @id @default(uuid())
  sessionId   String            @map("session_id")
  fileName    String            @map("file_name")
  mimeType    String            @map("mime_type")
  sizeBytes   Int               @map("size_bytes")
  checksum    String?
  storagePath String            @map("storage_path")
  status      ResumeAssetStatus @default(PENDING)
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")
  session     DiagnosisSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@map("resume_assets")
}

model JdInput {
  id         String           @id @default(uuid())
  sessionId  String           @unique @map("session_id")
  jdText     String?          @map("jd_text")
  jdUrl      String?          @map("jd_url")
  targetRole String?          @map("target_role")
  createdAt  DateTime         @default(now()) @map("created_at")
  updatedAt  DateTime         @updatedAt @map("updated_at")
  session    DiagnosisSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("jd_inputs")
}

model AnalysisRun {
  id           String            @id @default(uuid())
  sessionId    String            @map("session_id")
  status       AnalysisRunStatus @default(QUEUED)
  stage        AnalysisStage?
  progressPct  Int               @default(0) @map("progress_pct")
  errorMessage String?           @map("error_message")
  startedAt    DateTime?         @map("started_at")
  completedAt  DateTime?         @map("completed_at")
  createdAt    DateTime          @default(now()) @map("created_at")
  updatedAt    DateTime          @updatedAt @map("updated_at")
  session      DiagnosisSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  gapInsight   GapInsight?
  recommendation Recommendation?

  @@index([sessionId, createdAt])
  @@map("analysis_runs")
}

model GapInsight {
  id              String      @id @default(uuid())
  analysisRunId   String      @unique @map("analysis_run_id")
  readinessScore  Int         @map("readiness_score")
  strengths       Json
  gaps            Json
  confidence      Float
  createdAt       DateTime    @default(now()) @map("created_at")
  analysisRun     AnalysisRun @relation(fields: [analysisRunId], references: [id], onDelete: Cascade)

  @@map("gap_insights")
}

model Recommendation {
  id            String      @id @default(uuid())
  analysisRunId String      @unique @map("analysis_run_id")
  primaryAction Json        @map("primary_action")
  rationale     Json
  createdAt     DateTime    @default(now()) @map("created_at")
  analysisRun   AnalysisRun @relation(fields: [analysisRunId], references: [id], onDelete: Cascade)

  @@map("recommendations")
}

model JourneyState {
  id             String             @id @default(uuid())
  subjectType    JourneySubjectType @map("subject_type")
  subjectId      String             @map("subject_id")
  sessionId      String?            @map("session_id")
  currentFlow    String             @map("current_flow")
  currentStep    String             @map("current_step")
  resumePayload  Json               @map("resume_payload")
  createdAt      DateTime           @default(now()) @map("created_at")
  updatedAt      DateTime           @updatedAt @map("updated_at")
  session        DiagnosisSession?  @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([subjectType, subjectId])
  @@index([sessionId])
  @@map("journey_states")
}
