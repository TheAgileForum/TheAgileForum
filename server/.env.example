# Runtime mode (required)
NODE_ENV=development

# API port (required)
PORT=3001

# PostgreSQL connection string (required)
# Local default (see repo root docker-compose.yml):
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mybmadproj

# At least 32 chars. Never commit production secrets. (required)
JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-chars

# httpOnly cookie name for session JWT (optional)
AUTH_COOKIE_NAME=access_token

# Redis connection string for worker/scheduler runtime skeleton (required in full runtime)
REDIS_URL=redis://localhost:6379

# Runtime health ports for background processes (optional with defaults)
WORKER_PORT=3101
SCHEDULER_PORT=3102
