PORT=3001

# PostgreSQL (see repo root docker-compose.yml)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mybmadproj

# At least 32 random bytes as string — never commit real production secrets
JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-chars

# httpOnly cookie name for session JWT
AUTH_COOKIE_NAME=access_token
