# Runtime mode (required)
NODE_ENV=development

# API port (required)
PORT=3001

# Runtime/pool connection string (required)
# Use local Postgres for day-to-day dev OR Supabase Session Pooler URL.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mybmadproj

# Direct database connection string for migrations (required for Prisma directUrl)
# For local Postgres this can match DATABASE_URL.
# For Supabase, use direct host URL (not pooler) with sslmode=require.
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/mybmadproj

# At least 32 chars. Never commit production secrets. (required)
JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-chars

# httpOnly cookie name for session JWT (optional)
AUTH_COOKIE_NAME=access_token

# Redis connection string for worker/scheduler runtime skeleton (required in full runtime)
REDIS_URL=redis://localhost:6379

# Runtime health ports for background processes (optional with defaults)
WORKER_PORT=3101
SCHEDULER_PORT=3102

# Integration adapter mode: stub for local deterministic behavior, live for provider calls
INTEGRATION_PROVIDER_MODE=stub

# Stripe (optional — when set, standard checkout returns a Stripe Checkout URL)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=whsec_stub

# Razorpay India sandbox (optional — when set, IN checkout opens live Razorpay modal)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# OAuth (optional — dev stub works without these in non-production)
OAUTH_STUB_MODE=true
APP_PUBLIC_URL=http://localhost:5173
API_PUBLIC_URL=http://localhost:3001
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# Email verification (optional — off by default in dev)
REQUIRE_EMAIL_VERIFICATION=false
EMAIL_VERIFICATION_TTL_HOURS=48

# Enrollment ops notifications (stub email adapter)
OPS_ENROLLMENT_ALERT_EMAIL=ops@demo.local

# Integration timeout/retry baseline
INTEGRATION_TIMEOUT_MS=5000
INTEGRATION_MAX_RETRIES=2

# Sentry (optional but recommended for stage/prod)
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# PostHog server-side analytics (optional)
POSTHOG_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com

# Observability release tag and alert webhook target
OBSERVABILITY_RELEASE=local-dev
ALERT_WEBHOOK_URL=

# Microsoft Clarity project id (used by client instrumentation)
CLARITY_PROJECT_ID=

# Security baseline
CORS_ALLOWED_ORIGINS=http://localhost:5173
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=30
RESUME_UPLOAD_MAX_MB=5
