# Staging API — copy into Render / Fly / Railway secret store
# Replace placeholders; never commit real secrets.

NODE_ENV=production
PORT=3001

# Database (Supabase pooler + direct, or managed Postgres)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require
DIRECT_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require

JWT_SECRET=replace-with-32-char-minimum-random-secret
AUTH_COOKIE_NAME=access_token
REDIS_URL=redis://default:PASSWORD@HOST:6379

# Public URLs — must match DNS + TLS certificates
APP_PUBLIC_URL=https://app.staging.theagileforum.com
API_PUBLIC_URL=https://api.staging.theagileforum.com
CORS_ALLOWED_ORIGINS=https://app.staging.theagileforum.com

# OAuth (live on staging)
OAUTH_STUB_MODE=false
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# Commerce / integrations (stub ok for first staging slice)
INTEGRATION_PROVIDER_MODE=stub
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Observability (optional)
SENTRY_DSN=
POSTHOG_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com
OBSERVABILITY_RELEASE=staging

REQUIRE_EMAIL_VERIFICATION=false
OPS_ENROLLMENT_ALERT_EMAIL=ops@yourdomain.com
