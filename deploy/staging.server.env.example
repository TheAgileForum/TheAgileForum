# Staging API — copy to deploy/staging.server.env (local) or platform secret store (Render/Fly/Railway)
# Canonical URLs: deploy/domains.json
# Runbook: docs/staging-deploy.md
# Never commit real secrets.

NODE_ENV=production
PORT=3001

# Database — use Supabase Session pooler + direct URL (or managed Postgres)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require
DIRECT_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require

JWT_SECRET=replace-with-32-char-minimum-random-secret
AUTH_COOKIE_NAME=access_token
REDIS_URL=redis://default:PASSWORD@HOST:6379

# Public URLs — must match DNS + TLS (see deploy/domains.json)
APP_PUBLIC_URL=https://app.staging.theagileforum.com
API_PUBLIC_URL=https://api.staging.theagileforum.com
CORS_ALLOWED_ORIGINS=https://app.staging.theagileforum.com

# OAuth (live on staging — register redirect URIs in provider consoles)
OAUTH_STUB_MODE=false
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# Guest cart + commerce on staging
GUEST_CART_USE_DB=true
INTEGRATION_PROVIDER_MODE=live

# Stripe test mode on staging (sk_test_... — same keys as local sandbox)
STRIPE_SECRET_KEY=sk_test_REPLACE
STRIPE_WEBHOOK_SECRET=whsec_REPLACE

# Razorpay test mode for INR checkout
RAZORPAY_KEY_ID=rzp_test_REPLACE
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Email / ops
# Gates checkout (403 EMAIL_NOT_VERIFIED) when true; OAuth users auto-verified.
# Live email adapter logs only — verification links are not delivered until a real provider is wired.
# See docs/staging-deploy.md §8.
REQUIRE_EMAIL_VERIFICATION=true
OPS_ENROLLMENT_ALERT_EMAIL=ops@theagileforum.com

# Observability — set on staging API for live commerce events (see docs/staging-posthog-setup.md)
SENTRY_DSN=
POSTHOG_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com
OBSERVABILITY_RELEASE=staging

INTEGRATION_TIMEOUT_MS=5000
INTEGRATION_MAX_RETRIES=2
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=30
RESUME_UPLOAD_MAX_MB=5
