# Staging client — set in Vercel / Netlify / CI before `npm run build`
# See docs/staging-deploy.md

# API subdomain pattern (recommended when SPA and API are on different hosts)
VITE_API_URL=https://api.staging.theagileforum.com

# Leave VITE_API_URL unset if using single-origin /api proxy (vercel.json.example)

VITE_APP_ENV=staging
VITE_OBSERVABILITY_RELEASE=staging

# Optional analytics
# VITE_POSTHOG_KEY=phc_...
# VITE_POSTHOG_HOST=https://us.i.posthog.com
# VITE_CLARITY_PROJECT_ID=
