# Staging client — copy to deploy/staging.client.env (local) or Vercel/Netlify build env
# Canonical values: deploy/domains.json → staging.clientBuildEnv
# Runbook: docs/staging-deploy.md §4

# Recommended on Vercel staging: leave VITE_API_URL unset — client/vercel.json proxies /api to the API host.
# api-base.ts also forces same-origin /api on app.staging.theagileforum.com (ignores VITE_API_URL there).
# VITE_API_URL=https://api.staging.theagileforum.com

VITE_APP_ENV=staging
VITE_OBSERVABILITY_RELEASE=staging

# Optional analytics — docs/staging-posthog-setup.md
# VITE_POSTHOG_KEY=phc_...
# VITE_POSTHOG_HOST=https://us.i.posthog.com
# VITE_CLARITY_PROJECT_ID=
