# Example Render blueprint — copy to render.yaml and customize.
# Docs: https://render.com/docs/blueprint-spec

services:
  - type: web
    name: agile-forum-api-staging
    runtime: node
    rootDir: server
    # --include=dev: NODE_ENV=production skips devDependencies (@types/node, typescript, prisma CLI)
    buildCommand: npm ci --include=dev && npm run build
    startCommand: npm start
    healthCheckPath: /api/v1/health
    envVars:
      - key: NODE_ENV
        value: production
      - key: APP_PUBLIC_URL
        value: https://app.staging.theagileforum.com
      - key: API_PUBLIC_URL
        value: https://api.staging.theagileforum.com
      - key: CORS_ALLOWED_ORIGINS
        value: https://app.staging.theagileforum.com
      - key: OAUTH_STUB_MODE
        value: false
      - key: REQUIRE_EMAIL_VERIFICATION
        value: "true"
      - key: OBSERVABILITY_RELEASE
        value: staging
      - key: DATABASE_URL
        sync: false
      - key: DIRECT_URL
        sync: false
      - key: JWT_SECRET
        generateValue: true
      - key: REDIS_URL
        sync: false
      - key: LINKEDIN_CLIENT_ID
        sync: false
      - key: LINKEDIN_CLIENT_SECRET
        sync: false
      - key: GOOGLE_CLIENT_ID
        sync: false
      - key: GOOGLE_CLIENT_SECRET
        sync: false

# After first deploy: run `npm run db:deploy` and `npm run db:seed` in Render shell.
